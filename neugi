#!/usr/bin/env python3
"""
🤖 NEUGI CLI
===========
Usage: neugi [command]

Commands:
    start       Start NEUGI Swarm
    stop        Stop NEUGI Swarm
    restart     Restart NEUGI Swarm
    status      Check NEUGI status
    logs        View NEUGI logs
    wizard      Run setup wizard
    dashboard   Open dashboard
    technician  Open Technician (System Doctor)
    fix         Auto-fix issues
    help        Ask NEUGI Assistant

Examples:
    neugi start
    neugi status
    neugi technician
"""

import os
import sys
import signal
import subprocess
import time
import requests
import argparse
import urllib.request

# Config
NEUGI_DIR = os.path.expanduser("~/neugi")
NEUGI_SCRIPT = os.path.join(NEUGI_DIR, "neugi_swarm", "neugi_swarm.py")
NEUGI_LOG = os.path.join(NEUGI_DIR, "logs", "neugi.log")
PID_FILE = os.path.join(NEUGI_DIR, "neugi.pid")
PORT = 19888

# Colors
GREEN = '\033[0;32m'
RED = '\033[0;31m'
YELLOW = '\033[1;33m'
BLUE = '\033[0;34m'
ORANGE = '\033[0;33m'
NC = '\033[0m'

def log(msg, color=NC):
    print(f"{color}{msg}{NC}")

def is_running():
    """Check if NEUGI is running"""
    try:
        r = requests.get(f"http://localhost:{PORT}/health", timeout=2)
        return r.ok
    except:
        return False

def get_pid():
    """Get NEUGI PID"""
    if os.path.exists(PID_FILE):
        try:
            with open(PID_FILE) as f:
                return int(f.read().strip())
        except:
            pass
    return None

def check_health():
    """Get detailed health status"""
    try:
        r = requests.get(f"http://localhost:{PORT}/api/status", timeout=5)
        return r.json()
    except:
        return None

def open_dashboard(path="/"):
    """Open dashboard in browser"""
    import webbrowser
    url = f"http://localhost:{PORT}{path}"
    log(f"🌐 Opening: {url}", BLUE)
    webbrowser.open(url)

def cmd_start():
    """Start NEUGI"""
    if is_running():
        log(f"✅ NEUGI is already running!", GREEN)
        log(f"   📖 Dashboard: http://localhost:{PORT}")
        return
    
    # Ensure directory exists
    os.makedirs(NEUGI_DIR, exist_ok=True)
    os.makedirs(os.path.join(NEUGI_DIR, "logs"), exist_ok=True)
    
    # Check if files exist
    if not os.path.exists(NEUGI_SCRIPT):
        log(f"❌ NEUGI not found at {NEUGI_DIR}", RED)
        log("   Run: neugi install")
        return
    
    log("🚀 Starting NEUGI Swarm...", BLUE)
    
    # Check for issues first
    try:
        r = requests.get(f"http://localhost:{PORT}/api/status", timeout=3)
        issues = r.json().get("issues", [])
        if issues:
            log(f"⚠️ Issues detected:", YELLOW)
            for issue in issues:
                log(f"   - {issue}", YELLOW)
            log(f"\n🔧 Opening Technician...", ORANGE)
            open_dashboard("/technician")
            return
    except:
        pass
    
    # Start in background
    with open(NEUGI_LOG, "a") as f:
        proc = subprocess.Popen(
            [sys.executable, NEUGI_SCRIPT],
            cwd=NEUGI_DIR,
            stdout=f,
            stderr=subprocess.STDOUT,
            start_new_session=True
        )
    
    # Save PID
    with open(PID_FILE, "w") as f:
        f.write(str(proc.pid))
    
    # Wait and check
    for i in range(10):
        time.sleep(1)
        if is_running():
            log(f"✅ NEUGI started!", GREEN)
            log(f"   📖 Dashboard: http://localhost:{PORT}")
            return
    
    log(f"⚠️ NEUGI may not have started properly", YELLOW)
    log(f"   Check logs: neugi logs")

def cmd_stop():
    """Stop NEUGI"""
    if not is_running():
        log("❌ NEUGI is not running", RED)
        return
    
    log("🛑 Stopping NEUGI...", YELLOW)
    
    # Try to kill by PID
    pid = get_pid()
    if pid:
        try:
            os.kill(pid, signal.SIGTERM)
            time.sleep(2)
        except:
            pass
    
    # Also try pkill
    subprocess.run(["pkill", "-f", "neugi_swarm.py"], capture_output=True)
    
    # Remove PID file
    if os.path.exists(PID_FILE):
        os.remove(PID_FILE)
    
    log("✅ NEUGI stopped!", GREEN)

def cmd_restart():
    """Restart NEUGI"""
    log("🔄 Restarting NEUGI...", BLUE)
    cmd_stop()
    time.sleep(1)
    cmd_start()

def cmd_status():
    """Check NEUGI status"""
    if is_running():
        log(f"✅ NEUGI is RUNNING", GREEN)
        log(f"   📖 Dashboard: http://localhost:{PORT}")
        
        # Get detailed info
        data = check_health()
        if data:
            log(f"\n   🧠 Model: {data.get('ollama', {}).get('models', 'N/A')} loaded")
            
            issues = data.get("issues", [])
            if issues:
                log(f"\n   ⚠️ ISSUES DETECTED:", YELLOW)
                for issue in issues:
                    log(f"      - {issue}", YELLOW)
                log(f"\n   🔧 Run: neugi technician", ORANGE)
    else:
        log(f"❌ NEUGI is NOT running", RED)
        log(f"   To start: neugi start")

def cmd_logs():
    """Show NEUGI logs"""
    if not os.path.exists(NEUGI_LOG):
        log("❌ No logs found", RED)
        return
    
    log(f"📋 Last 30 lines of logs:", BLUE)
    print("-" * 50)
    
    with open(NEUGI_LOG) as f:
        lines = f.readlines()
        for line in lines[-30:]:
            print(line.rstrip())

def cmd_wizard():
    """Run setup wizard"""
    wizard_script = os.path.join(NEUGI_DIR, "neugi_wizard.py")
    
    if not os.path.exists(wizard_script):
        log("❌ Wizard not found", RED)
        log("   Run install first: neugi install")
        return
    
    log("🎯 Running setup wizard...", BLUE)
    subprocess.run([sys.executable, wizard_script], cwd=NEUGI_DIR)

def cmd_dashboard():
    """Open dashboard"""
    open_dashboard("/")

def cmd_technician():
    """Open Technician - System Doctor"""
    if not is_running():
        # Try to start minimal server first
        log("⚠️ NEUGI not running. Starting minimal server...", YELLOW)
        cmd_start()
        time.sleep(2)
    
    open_dashboard("/technician")

def cmd_fix():
    """Auto-fix issues"""
    log("🔧 Running auto-fix...", BLUE)
    
    if not is_running():
        log("❌ NEUGI not running. Starting first...", YELLOW)
        cmd_start()
        time.sleep(2)
    
    try:
        r = requests.get(f"http://localhost:{PORT}/api/fix", timeout=10)
        data = r.json()
        
        fixes = data.get("fixes", [])
        if fixes:
            for fix in fixes:
                log(f"   ✅ {fix}", GREEN)
        else:
            log(f"   ⚠️ No auto-fixes available", YELLOW)
            
    except Exception as e:
        log(f"❌ Error: {e}", RED)
    
    # Open technician for manual fix
    log(f"\n🔧 Opening Technician for more options...", ORANGE)
    open_dashboard("/technician")

def cmd_help():
    """NEUGI Assistant - help with questions"""
    assistant_script = os.path.join(NEUGI_DIR, "neugi_assistant.py")
    
    if not os.path.exists(assistant_script):
        log("❌ Assistant not found. Run install first!", RED)
        return
    
    if len(sys.argv) > 2:
        question = " ".join(sys.argv[2:])
        result = subprocess.run(
            [sys.executable, assistant_script, question],
            cwd=NEUGI_DIR,
            capture_output=True,
            text=True
        )
        print(result.stdout)
    else:
        log("🎯 NEUGI Assistant", BLUE)
        print("\nAsk me anything!")
        print("Examples:")
        print("  neugi help how to install")
        print("  neugi help how to start")
        print("  neugi help api key")
        print("  neugi help ollama")

# ============================================================
# MAIN
# ============================================================

def main():
    parser = argparse.ArgumentParser(
        description="🤖 NEUGI CLI - Neural General Intelligence"
    )
    
    subparsers = parser.add_subparsers(dest="command", help="Commands")
    
    subparsers.add_parser("start", help="Start NEUGI")
    subparsers.add_parser("stop", help="Stop NEUGI")
    subparsers.add_parser("restart", help="Restart NEUGI")
    subparsers.add_parser("status", help="Check NEUGI status")
    subparsers.add_parser("logs", help="View NEUGI logs")
    subparsers.add_parser("wizard", help="Run setup wizard")
    subparsers.add_parser("dashboard", help="Open dashboard")
    subparsers.add_parser("technician", help="Open Technician (System Doctor)")
    subparsers.add_parser("fix", help="Auto-fix issues")
    subparsers.add_parser("help", help="Ask NEUGI Assistant")
    subparsers.add_parser("install", help="Install NEUGI")
    
    args = parser.parse_args()
    
    # No command = show help
    if not args.command:
        print(__doc__)
        return
    
    # Run command
    commands = {
        "start": cmd_start,
        "stop": cmd_stop,
        "restart": cmd_restart,
        "status": cmd_status,
        "logs": cmd_logs,
        "wizard": cmd_wizard,
        "dashboard": cmd_dashboard,
        "technician": cmd_technician,
        "fix": cmd_fix,
        "help": cmd_help,
    }
    
    if args.command == "install":
        log("📥 Running NEUGI installer...", BLUE)
        subprocess.run([
            "bash", "-c",
            "curl -fsSL https://raw.githubusercontent.com/atharia-agi/neugi_swarm/main/install.sh | bash"
        ])
    elif args.command in commands:
        commands[args.command]()
    else:
        log(f"❌ Unknown command: {args.command}", RED)

if __name__ == "__main__":
    main()
