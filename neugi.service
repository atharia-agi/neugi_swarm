[Unit]
Description=NEUGI Swarm - Neural General Intelligence
After=network.target ollama.service
Wants=ollama.service

[Service]
Type=simple
User=%u
WorkingDirectory=%h/neugi
ExecStart=/usr/bin/python3 %h/neugi/neugi_swarm.py
Restart=always
RestartSec=10

# Environment
Environment=OLLAMA_URL=http://localhost:11434
Environment=PYTHONUNBUFFERED=1

# Logging
StandardOutput=append:%h/neugi/logs/neugi.log
StandardError=append:%h/neugi/logs/neugi_error.log

[Install]
WantedBy=default.target
