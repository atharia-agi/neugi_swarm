# NEUGI .gitignore
# =================

# Sensitive files
*.env
.env.local
.env.*
config_secrets.py
secrets.py
credentials.py
*.pem
*.key

# Logs
logs/
*.log

# Data
data/
*.db
*.sqlite

# Models
models/
*.gguf
*.bin

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Temp
tmp/
temp/
*.tmp

# Python
__pycache__/
*.py[cod]
*$py.class
*.pyc
.Python
*.egg-info/
dist/
build/
eggs/
*.egg

# Node
node_modules/

# Cache
.ruff_cache/
.pytest_cache/
.coverage
htmlcov/

# Research & Reverse Engineering (Local Only)
research/
git_files_browser.py
# Note: AUDIT_README.md should be committed for external audit
